{{#if extensionNumber}}
<Redirect method="GET">{{base_url}}/extensions/{{extensionNumber}}</Redirect>
{{/if}}
{{#if menu.redirection}}
<Redirect method="GET">{{menu.redirection}}</Redirect>
{{else}}
{{#if error}}
<Play>{{base_url}}/audio/invalid-selection.wav</Play>
{{/if}}
<Gather action="{{self}}" actionOnEmptyResult="false" method="GET" hints="{{#each menu.hints}}{{.}}, {{/each}}" input="dtmf" numDigits="{{menu.numDigits}}" timeout="7">
{{#if call.greeting}}
<Play>{{base_url}}{{menu.greeting}}</Play>
{{/if}}
<Play>{{base_url}}{{menu.prompt}}</Play>
</Gather>
{{/if}}
