{{else}}
<Play method="GET">{{base_url}}/audio/conferences.aiff</Play>
{{/if}}
<Redirect>{{base_url}}/documents/zoom?room=2157551065{{#if call.callout}}&amp;callout=true{{/if}}</Redirect>
